{
  "RecipeFormatVersion": "2020-01-25",
  "ComponentName": "com.example.ListNamedShadowsForThingC",
  "ComponentVersion": "1.0.0",
  "ComponentDescription": "A component that lists named shadows for a thing.",
  "ComponentPublisher": "Amazon",
  "ComponentConfiguration": {
    "DefaultConfiguration": {
      "accessControl": {
        "aws.greengrass.ShadowManager": {
          "com.example.ListNamedShadowsForThingC:shadow:1": {
            "policyDescription": "Allows listing named shadows for a thing.",
            "operations": ["aws.greengrass#ListNamedShadowsForThing"],
            "resources": ["*"]
          }
        }
      }
    }
  },
  "Manifests": [
    {
      "Platform": {
        "os": "linux"
      },
      "Lifecycle": {
        "run": "{artifacts:path}/sample_list_named_shadows_for_thing"
      },
      "Artifacts": [
        {
          "URI": "s3://amzn-s3-demo-bucket/artifacts/com.example.ListNamedShadowsForThingC/1.0.0/sample_list_named_shadows_for_thing",
          "Permission": {
            "Execute": "OWNER"
          }
        }
      ]
    }
  ]
}
