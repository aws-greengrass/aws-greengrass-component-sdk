{
  "RecipeFormatVersion": "2020-01-25",
  "ComponentName": "com.example.UpdateConfigurationPython",
  "ComponentVersion": "1.0.0",
  "ComponentDescription": "A component that updates a configuration value.",
  "ComponentPublisher": "Amazon",
  "ComponentConfiguration": {
    "DefaultConfiguration": {
      "mqtt": {
        "port": 8883
      }
    }
  },
  "Manifests": [
    {
      "Platform": {
        "os": "linux",
        "runtime": "*"
      },
      "Lifecycle": {
        "run": "python3 -u {artifacts:path}/update_configuration.py"
      },
      "Artifacts": [
        {
          "URI": "s3://amzn-s3-demo-bucket/artifacts/com.example.UpdateConfigurationPython/1.0.0/update_configuration.py",
          "Permission": {
            "Read": "ALL"
          }
        }
      ]
    }
  ]
}
