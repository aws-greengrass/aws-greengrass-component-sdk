{
  "RecipeFormatVersion": "2020-01-25",
  "ComponentName": "com.example.GetThingShadowPython",
  "ComponentVersion": "1.0.0",
  "ComponentDescription": "A component that gets a thing shadow.",
  "ComponentPublisher": "Amazon",
  "ComponentConfiguration": {
    "DefaultConfiguration": {
      "accessControl": {
        "aws.greengrass.ShadowManager": {
          "com.example.GetThingShadowPython:shadow:1": {
            "policyDescription": "Allows getting thing shadows.",
            "operations": ["aws.greengrass#GetThingShadow"],
            "resources": ["*"]
          }
        }
      }
    }
  },
  "Manifests": [
    {
      "Platform": {
        "os": "linux"
      },
      "Lifecycle": {
        "run": "python3 -u {artifacts:path}/get_thing_shadow.py"
      },
      "Artifacts": [
        {
          "URI": "s3://amzn-s3-demo-bucket/artifacts/com.example.GetThingShadowPython/1.0.0/get_thing_shadow.py",
          "Permission": {
            "Read": "ALL"
          }
        }
      ]
    }
  ]
}
